# Copy this file to .env and fill in only the values you need.
# AgentBreaker auto-loads .env in the CLI, campaign runner, and harness.
# NEVER commit .env to git.
#
# Any api_key_env or ${ENV_VAR} you reference in target_config.yaml can be
# added here. The defaults below cover the built-in judge/generator settings
# plus the bundled target integrations.

# ---------------------------------------------------------------------------
# Core model API keys
# target_config.yaml defaults:
# - judge.config.api_key_env     -> OPENAI_API_KEY
# - planner.use_judge_config     -> reuses the judge provider/key
# - generator.config.api_key_env -> OPENAI_API_KEY
# ---------------------------------------------------------------------------
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
GOOGLE_API_KEY=

# ---------------------------------------------------------------------------
# Optional service / guardrail APIs
# ---------------------------------------------------------------------------
CTF_API_TOKEN=
CTF_TEAM_ID=
GUARDRAIL_API_KEY=
AZURE_CS_RESOURCE=
AZURE_CONTENT_SAFETY_KEY=
APP_SERVICE_TOKEN=

# ---------------------------------------------------------------------------
# Script / HTTP target credentials
# ---------------------------------------------------------------------------
AGENT_API_KEY=
AGENT_ENDPOINT=

# ---------------------------------------------------------------------------
# Browser target credentials
# ---------------------------------------------------------------------------
CHATBOT_TEST_USER=
CHATBOT_TEST_PASS=

# ---------------------------------------------------------------------------
# Resistance CTF (https://resistance-iota.vercel.app)
# Leave user/pass blank to auto-register throwaway accounts per run.
# ---------------------------------------------------------------------------
RESISTANCE_URL=https://resistance-iota.vercel.app
RESISTANCE_USER=
RESISTANCE_PASS=
RESISTANCE_DIFF=lini
RESISTANCE_ACCOUNT_SCOPE=attack

# ---------------------------------------------------------------------------
# Prompt Airlines CTF (https://promptairlines.com)
# Leave challenge id blank to allow automatic stage progression.
# VERIFY_TLS defaults to false because some local Python cert stores fail to
# validate the remote chain on certain hosts.
# ---------------------------------------------------------------------------
PROMPT_AIRLINES_URL=https://promptairlines.com
PROMPT_AIRLINES_CHALLENGE_ID=
PROMPT_AIRLINES_VERIFY_TLS=false
PROMPT_AIRLINES_TIMEOUT_SECONDS=30
PROMPT_AIRLINES_AUTO_SUBMIT_FLAGS=true
